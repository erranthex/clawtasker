{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClawTasker Mission Plan",
  "type": "object",
  "properties": {
    "source": {
      "type": "string"
    },
    "mission": {
      "type": "object",
      "required": [
        "title",
        "objective"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "objective": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "planned",
            "active",
            "blocked",
            "review",
            "done"
          ]
        },
        "priority": {
          "type": "string",
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3"
          ]
        },
        "horizon": {
          "type": "string",
          "enum": [
            "Today",
            "This Week",
            "This Month",
            "Later"
          ]
        },
        "owner": {
          "type": "string"
        },
        "project_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "task_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_specialists": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "assigned_agents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "success_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string"
                  },
                  "owner": {
                    "type": "string"
                  },
                  "detail": {
                    "type": "string"
                  }
                }
              }
            ]
          }
        },
        "risks": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "severity": {
                    "type": "string",
                    "enum": [
                      "low",
                      "medium",
                      "high",
                      "critical"
                    ]
                  },
                  "status": {
                    "type": "string"
                  },
                  "owner": {
                    "type": "string"
                  },
                  "mitigation": {
                    "type": "string"
                  }
                }
              }
            ]
          }
        },
        "milestones": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string"
                  },
                  "due_date": {
                    "type": "string"
                  }
                }
              }
            ]
          }
        }
      }
    }
  }
}
